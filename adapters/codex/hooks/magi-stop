#!/bin/sh

set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
script_path="$script_dir/magi-stop.mjs"

run_with_node() {
  candidate=$1
  shift

  if [ -z "$candidate" ]; then
    return 1
  fi

  if [ "$candidate" = "node" ]; then
    node_bin=$(command -v node 2>/dev/null || true)
  else
    node_bin=$candidate
  fi

  if [ ! -x "$node_bin" ]; then
    return 1
  fi

  major=$("$node_bin" -p 'Number(process.versions.node.split(".")[0])' 2>/dev/null || true)
  case "$major" in
    ""|*[!0-9]*)
      return 1
      ;;
  esac

  if [ "$major" -lt 18 ]; then
    return 1
  fi

  exec "$node_bin" "$script_path" "$@"
}

for candidate in "${OPEN_MAGI_NODE:-}" "${NODE:-}" node "$HOME"/.nvm/versions/node/*/bin/node /usr/local/bin/node /usr/bin/node; do
  run_with_node "$candidate" "$@" || true
done

printf '%s\n' '{"decision":"block","reason":"<MAGI_STOP_BACKSTOP>\nMagi Stop hook requires Node.js 18 or newer, but no compatible node executable was found.\nSet OPEN_MAGI_NODE to a Node.js 18+ binary or start Codex with a PATH that includes modern Node.js.\n</MAGI_STOP_BACKSTOP>"}'
